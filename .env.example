# ============================================================
#  Alex-AI secrets template  —  copy this file to ".env" and fill it in.
# ============================================================
# Read server-side by server.py. The browser NEVER sees this key.
# Get a free key at: https://build.nvidia.com/

API_KEY=your_nvidia_api_key_here

# Optional server settings
# PORT=8000
# UPSTREAM_HOST=integrate.api.nvidia.com

# For reference (the browser reads these from js/config.js, not here)
TEXT_MODEL=openai/gpt-oss-120b
VISION_MODEL=meta/llama-3.2-11b-vision-instruct
